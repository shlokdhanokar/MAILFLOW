# ============================================
# MAILFLOW Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit the .env file to version control!

# --- Mode Selection ---
# CLASSIFIER_MODE: "bert" (local, requires email_bert_model/) or "gemini" (cloud, lightweight)
CLASSIFIER_MODE=gemini

# DB_MODE: "mysql" (full database server) or "sqlite" (file-based, zero config)
DB_MODE=sqlite

# --- Gmail IMAP/SMTP Credentials ---
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password-here

# --- Google Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- MySQL Database (only needed if DB_MODE=mysql) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=email_tickets

# --- SQLite (only needed if DB_MODE=sqlite) ---
SQLITE_PATH=mailflow.db

# --- Flask API ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# --- BERT Model (only needed if CLASSIFIER_MODE=bert) ---
BERT_MODEL_PATH=email_bert_model
